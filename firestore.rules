rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own usage data (quota display in app)
    match /users/{userId}/usage/{day} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only Cloud Functions can write (admin SDK bypasses rules)
      allow write: if false;
    }

    // Rate limit docs — Cloud Functions only (admin SDK)
    match /ratelimit/{doc} {
      allow read, write: if false;
    }

    // Smart defaults rate limit — Cloud Functions only (admin SDK)
    match /ratelimit_sd/{doc} {
      allow read, write: if false;
    }

    // Smart defaults — authenticated users can read, Cloud Functions write via admin SDK
    match /smartDefaults/{itemName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Smart default corrections — Cloud Functions only (admin SDK)
    match /smartDefaultCorrections/{itemName}/{document=**} {
      allow read, write: if false;
    }

    // Smart defaults correction rate limit — Cloud Functions only (admin SDK)
    match /ratelimit_sc/{doc} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
